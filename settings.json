{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "1",
    "CLAUDE_CODE_DISABLE_AUTO_MEMORY": "0",
    "ENABLE_TOOL_SEARCH": "true"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "Glob(*)",
      "Grep(*)",
      "Bash(*)",
      "WebFetch(*)",
      "WebSearch(*)",
      "Skill(*)",
      "Agent(*)",
      "ToolSearch(*)",
      "TaskCreate(*)",
      "TaskUpdate(*)",
      "TaskGet(*)",
      "TaskList(*)",
      "TaskOutput(*)",
      "TaskStop(*)",
      "ToolSearch(*)"
    ],
    "deny": [],
    "ask": [],
    "defaultMode": "acceptEdits"
  },
  "model": "haiku",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/hook-dispatcher.sh"
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/claude-notify.sh completed"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/hook-dispatcher.sh"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/hook-dispatcher.sh"
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/claude-notify.sh approval"
          }
        ]
      }
    ],
    "Elicitation": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/hook-dispatcher.sh"
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/claude-notify.sh elicitation"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/command-guard.sh"
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/hook-dispatcher.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/track-agent-tokens.sh"
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/hook-dispatcher.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "pwsh -NoProfile -NonInteractive -File \"C:\\Users\\willem\\.claude\\statusline-command.ps1\""
  },
  "enabledPlugins": {
    "slack@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "notion@claude-plugins-official": true,
    "microsoft-docs@claude-plugins-official": true,
    "mcp-server-dev@claude-plugins-official": true,
    "chrome-devtools-mcp@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true
  },
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "Processing"
    ]
  },
  "effortLevel": "medium",
  "agent": "main",
  "autoDreamEnabled": true,
  "showThinkingSummaries": true,
  "skipDangerousModePermissionPrompt": true
}
