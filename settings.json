{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "agent": "main",
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "autoDreamEnabled": true,
  "effortLevel": "medium",
  "enabledPlugins": {
    "chrome-devtools-mcp@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "mcp-server-dev@claude-plugins-official": true,
    "microsoft-docs@claude-plugins-official": true,
    "notion@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "slack@claude-plugins-official": true
  },
  "env": {
    "CLAUDE_CODE_DISABLE_AUTO_MEMORY": "0",
    "CLAUDE_CODE_ENABLE_TELEMETRY": "1",
    "ENABLE_TOOL_SEARCH": "true"
  },
  "hooks": {
    "Elicitation": [
      {
        "hooks": [
          {
            "command": "bash $HOME/.claude/hooks/hook-debug-dump.sh Elicitation",
            "type": "command"
          },
          {
            "command": "bash $HOME/.claude/hooks/hook-dispatcher.sh",
            "type": "command"
          },
          {
            "command": "bash $HOME/.claude/hooks/claude-notify.sh elicitation",
            "type": "command"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "command": "bash $HOME/.claude/hooks/hook-debug-dump.sh Notification",
            "type": "command"
          },
          {
            "command": "bash $HOME/.claude/hooks/hook-dispatcher.sh",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "command": "bash $HOME/.claude/hooks/hook-debug-dump.sh PermissionRequest",
            "type": "command"
          },
          {
            "command": "bash $HOME/.claude/hooks/hook-dispatcher.sh",
            "type": "command"
          },
          {
            "command": "bash $HOME/.claude/hooks/claude-notify.sh approval",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "bash $HOME/.claude/hooks/hook-debug-dump.sh PostToolUse",
            "type": "command"
          },
          {
            "command": "bash $HOME/.claude/hooks/track-agent-tokens.sh",
            "type": "command"
          },
          {
            "command": "bash $HOME/.claude/hooks/hook-dispatcher.sh",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "command": "bash $HOME/.claude/hooks/hook-debug-dump.sh PostToolUseFailure",
            "type": "command"
          },
          {
            "command": "bash -c 'cat >> $HOME/.claude/failed_commands.md'",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "bash $HOME/.claude/hooks/hook-debug-dump.sh PreToolUse",
            "type": "command"
          },
          {
            "command": "bash $HOME/.claude/hooks/command-guard.sh",
            "type": "command"
          },
          {
            "command": "bash $HOME/.claude/hooks/hook-dispatcher.sh",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "bash $HOME/.claude/hooks/hook-debug-dump.sh Stop",
            "type": "command"
          },
          {
            "command": "bash $HOME/.claude/hooks/hook-dispatcher.sh",
            "type": "command"
          },
          {
            "command": "bash $HOME/.claude/hooks/claude-notify.sh completed",
            "type": "command"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bash $HOME/.claude/hooks/hook-debug-dump.sh SessionStart",
            "type": "command"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "command": "bash $HOME/.claude/hooks/hook-debug-dump.sh SessionEnd",
            "type": "command"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "bash $HOME/.claude/hooks/hook-debug-dump.sh UserPromptSubmit",
            "type": "command"
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          {
            "command": "bash $HOME/.claude/hooks/hook-debug-dump.sh StopFailure",
            "type": "command"
          }
        ]
      }
    ],
    "PermissionDenied": [
      {
        "hooks": [
          {
            "command": "bash $HOME/.claude/hooks/hook-debug-dump.sh PermissionDenied",
            "type": "command"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "command": "bash $HOME/.claude/hooks/hook-debug-dump.sh SubagentStart",
            "type": "command"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "command": "bash $HOME/.claude/hooks/hook-debug-dump.sh SubagentStop",
            "type": "command"
          }
        ]
      }
    ],
    "TaskCreated": [
      {
        "hooks": [
          {
            "command": "bash $HOME/.claude/hooks/hook-debug-dump.sh TaskCreated",
            "type": "command"
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "command": "bash $HOME/.claude/hooks/hook-debug-dump.sh TaskCompleted",
            "type": "command"
          }
        ]
      }
    ],
    "TeammateIdle": [
      {
        "hooks": [
          {
            "command": "bash $HOME/.claude/hooks/hook-debug-dump.sh TeammateIdle",
            "type": "command"
          }
        ]
      }
    ],
    "InstructionsLoaded": [
      {
        "hooks": [
          {
            "command": "bash $HOME/.claude/hooks/hook-debug-dump.sh InstructionsLoaded",
            "type": "command"
          }
        ]
      }
    ],
    "ConfigChange": [
      {
        "hooks": [
          {
            "command": "bash $HOME/.claude/hooks/hook-debug-dump.sh ConfigChange",
            "type": "command"
          }
        ]
      }
    ],
    "CwdChanged": [
      {
        "hooks": [
          {
            "command": "bash $HOME/.claude/hooks/hook-debug-dump.sh CwdChanged",
            "type": "command"
          }
        ]
      }
    ],
    "FileChanged": [
      {
        "hooks": [
          {
            "command": "bash $HOME/.claude/hooks/hook-debug-dump.sh FileChanged",
            "type": "command"
          }
        ]
      }
    ],
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "command": "bash $HOME/.claude/hooks/hook-debug-dump.sh WorktreeCreate",
            "type": "command"
          }
        ]
      }
    ],
    "WorktreeRemove": [
      {
        "hooks": [
          {
            "command": "bash $HOME/.claude/hooks/hook-debug-dump.sh WorktreeRemove",
            "type": "command"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "command": "bash $HOME/.claude/hooks/hook-debug-dump.sh PreCompact",
            "type": "command"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "command": "bash $HOME/.claude/hooks/hook-debug-dump.sh PostCompact",
            "type": "command"
          }
        ]
      }
    ],
    "ElicitationResult": [
      {
        "hooks": [
          {
            "command": "bash $HOME/.claude/hooks/hook-debug-dump.sh ElicitationResult",
            "type": "command"
          }
        ]
      }
    ]
  },
  "includeCoAuthoredBy": false,
  "model": "sonnet",
  "permissions": {
      "allow": [
        "Read(*)",
        "Write(*)",
        "Edit(*)",
        "Glob(*)",
        "Grep(*)",
        "Bash(*)",
        "WebFetch(*)",
        "WebSearch(*)",
        "Skill(*)",
        "Agent(*)",
        "ToolSearch(*)",
        "TaskCreate(*)",
        "TaskUpdate(*)",
        "TaskGet(*)",
        "TaskList(*)",
        "TaskOutput(*)",
        "TaskStop(*)",
        "ToolSearch(*)"
      ],
      "deny": []
    },
  "showThinkingSummaries": true,
  "skipDangerousModePermissionPrompt": true,
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "Processing"
    ]
  },
  "statusLine": {
    "command": "pwsh -NoProfile -NonInteractive -File \"C:\\Users\\willem\\.claude\\statusline-command.ps1\"",
    "type": "command"
  }
}