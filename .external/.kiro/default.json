{
  "name": "default",
  "description": "Sandboxed agent for unsupervised research and code tasks",
  "tools": [
    "read",
    "write",
    "shell",
    "aws",
    "grep",
    "glob",
    "introspect",
    "delegate"
  ],
  "allowedTools": [],
  "toolsSettings": {
    "execute_bash": {
      "denyByDefault": true,
      "autoAllowReadonly": true,
      "allowedCommands": [
        "ls.*",
        "cat .*",
        "head .*",
        "tail .*",
        "wc .*",
        "echo .*",
        "pwd",
        "which .*",
        "whoami",
        "date.*",
        "env",
        "env .*",
        "printenv.*",
        "file .*",
        "stat .*",
        "du .*",
        "df .*",
        "uname.*",
        "id",
        "git status.*",
        "git log.*",
        "git diff.*",
        "git branch.*",
        "git show.*",
        "git remote -v",
        "git rev-parse.*",
        "gh\\.exe pr list.*",
        "gh\\.exe pr view.*",
        "gh\\.exe pr checks.*",
        "gh\\.exe issue list.*",
        "gh\\.exe issue view.*",
        "gh\\.exe repo view.*",
        "gh\\.exe run list.*",
        "gh\\.exe run view.*",
        "gh\\.exe release list.*",
        "gh\\.exe release view.*",
        "gh\\.exe --version",
        "gh\\.exe auth status",
        "cargo check.*",
        "cargo build.*",
        "cargo test.*",
        "cargo clippy.*",
        "cargo fmt.*",
        "cargo run.*",
        "npm run.*",
        "npm test.*",
        "npm install.*",
        "npx .*",
        "node .*",
        "rustc .*",
        "gcc .*",
        "g\\+\\+ .*",
        "make.*",
        "cmake.*",
        "dotnet .*",
        "go build.*",
        "go test.*",
        "go run.*",
        "jq .*",
        "sed .*",
        "awk .*",
        "sort .*",
        "uniq .*",
        "cut .*",
        "tr .*",
        "diff .*",
        "tree .*",
        "basename .*",
        "dirname .*",
        "realpath .*",
        "readlink .*",
        "mkdir .*",
        "touch .*",
        "tee .*",
        "curl .*",
        "wget .*",
      ],
      "deniedCommands": [
        "rm .*",
        "sudo .*",
        "su .*",
        "dd .*",
        "mkfs .*",
        "shred .*",
        "wipefs .*",
        "fdisk .*",
        "parted .*",
        "reboot.*",
        "shutdown.*",
        "poweroff.*",
        "mount .*",
        "umount .*",
        "chmod -R .*",
        "chown -R .*",
        "systemctl .*",
        "init .*",
        "pip .*"
      ]
    },
    "fs_write": {
      "deniedPaths": ["/mnt/[a-z]/**", "/etc/**", "~/.ssh/**", "/boot/**", "/sys/**", "/proc/**"],
      "fallbackAction": "interactive"
    }
  }
}
